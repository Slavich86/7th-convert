{
  "id": "wav_pcm",
  "name": "WAV PCM 24-bit",
  "group": "Audio",
  "output": {
    "container": "wav",
    "extension": "wav"
  },
  "video": {
    "enabled": false
  },
  "audio": {
    "enabled": true,
    "codec": "pcm_s24le",
    "sample_rate": 48000,
    "channels": "source"
  },
  "filters": {
    "scale": "keep",
    "fps": "source",
    "force_even_dimensions": false
  }
}

