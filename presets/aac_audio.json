{
  "id": "aac_audio",
  "name": "AAC Audio",
  "group": "Audio",
  "output": {
    "container": "adts",
    "extension": "aac"
  },
  "video": {
    "enabled": false
  },
  "audio": {
    "enabled": true,
    "codec": "aac",
    "bitrate": "192k",
    "sample_rate": 48000,
    "channels": "source"
  },
  "filters": {
    "scale": "keep",
    "fps": "source",
    "force_even_dimensions": false
  }
}
