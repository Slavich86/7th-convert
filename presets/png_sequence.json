{
  "id": "png_sequence",
  "name": "PNG Sequence",
  "group": "Image Sequence",
  "output": {
    "container": "image2",
    "extension": "png",
    "requires_pattern": true
  },
  "video": {
    "enabled": true,
    "codec": "png",
    "pix_fmt": "rgb24"
  },
  "audio": {
    "enabled": false
  },
  "filters": {
    "scale": "keep",
    "fps": "source",
    "force_even_dimensions": false
  }
}
