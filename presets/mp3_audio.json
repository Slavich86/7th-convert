{
  "id": "mp3_audio",
  "name": "MP3 Audio",
  "group": "Audio",
  "output": {
    "container": "mp3",
    "extension": "mp3"
  },
  "video": {
    "enabled": false
  },
  "audio": {
    "enabled": true,
    "codec": "libmp3lame",
    "bitrate": "192k",
    "sample_rate": 48000,
    "channels": "source"
  },
  "filters": {
    "scale": "keep",
    "fps": "source",
    "force_even_dimensions": false
  }
}
