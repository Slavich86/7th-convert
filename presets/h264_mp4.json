{
  "id": "h264_mp4",
  "name": "H.264 MP4",
  "group": "Video",
  "output": {
    "container": "mp4",
    "extension": "mp4"
  },
  "video": {
    "enabled": true,
    "codec": "libx264",
    "profile": "high",
    "pix_fmt": "yuv420p",
    "crf": 20
  },
  "audio": {
    "enabled": true,
    "codec": "aac",
    "bitrate": "192k",
    "sample_rate": 48000,
    "channels": "source"
  },
  "filters": {
    "scale": "keep",
    "fps": "source",
    "force_even_dimensions": true
  }
}

